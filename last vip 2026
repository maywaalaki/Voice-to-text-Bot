async def safe_execute(coro):
    try:
        return await coro
    except Exception:
        return None

async def show_error(call=None, client=None, chat_id=None, reply_id=None):
    msg = "Error 😓"
    if call:
        await safe_execute(call.answer(msg, show_alert=True))
    elif client and chat_id and reply_id:
        await safe_execute(client.send_message(chat_id, msg, reply_to_message_id=reply_id))

def transcribe_local_file(file_path, language=None):
    if language == "":
        language = None
    segments, _ = whisper_model.transcribe(file_path, language=language)
    return " ".join(segment.text for segment in segments).strip()

async def transcribe_local_file_async(file_path, language=None):
    return await asyncio.to_thread(transcribe_local_file, file_path, language)

def ask_groq(text, instruction):
    url = "https://api.groq.com/openai/v1/chat/completions"
    headers = {"Authorization": f"Bearer {GROQ_API_KEY}", "Content-Type": "application/json"}
    payload = {
        "model": GROQ_TEXT_MODEL,
        "messages": [
            {"role": "system", "content": instruction},
            {"role": "user", "content": text}
        ],
        "max_tokens": 7900,
        "temperature": 0.2
    }
    resp = requests.post(url, headers=headers, json=payload, timeout=REQUEST_TIMEOUT)
    resp.raise_for_status()
    return resp.json()["choices"][0]["message"]["content"]

async def ask_groq_async(text, instruction):
    return await asyncio.to_thread(ask_groq, text, instruction)

def build_action_keyboard(text_len):
    return InlineKeyboardMarkup([[InlineKeyboardButton("Get Summarize", callback_data="summarize_menu|")]]) if text_len > 1000 else None

def build_lang_keyboard(origin):
    btns = [[InlineKeyboardButton(lbl, callback_data=f"lang|{code}|{lbl}|{origin}") for lbl, code in LANGS[i:i+3]] for i in range(0, len(LANGS), 3)]
    return InlineKeyboardMarkup(btns)

def build_summarize_keyboard(origin):
    opts = ["Short", "Detailed", "Bulleted"]
    return InlineKeyboardMarkup([[InlineKeyboardButton(opt, callback_data=f"summopt|{opt}|{origin}")] for opt in opts])

