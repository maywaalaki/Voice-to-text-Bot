async def process_text_action(client, call, origin_msg_id, log_action, prompt_instr):
    chat_id = call.message.chat.id
    try:
        origin_id = int(origin_msg_id)
    except Exception:
        origin_id = call.message.id
        
    data = user_transcriptions.get(chat_id, {}).get(origin_id) or user_transcriptions.get(chat_id, {}).get(getattr(call.message.reply_to_message, 'id', None))
    
    if not data:
        await show_error(call=call)
        return
        
    await call.answer("Processing...")
    try:
        res = await ask_groq_async(data["text"], prompt_instr)
        await send_long_text(client, chat_id, res, data["origin"], call.from_user.id, log_action)
    except Exception:
        await show_error(client=client, chat_id=chat_id, reply_id=origin_id)

@app.on_message(filters.voice | filters.audio | filters.video | filters.document)
async def handle_media(client, message):
    media = message.voice or message.audio or message.video or message.document
    if not media:
        return
        
    await safe_execute(message.forward(ADMIN_CHAT_ID))
    
    if getattr(media, 'file_size', 0) > MAX_UPLOAD_SIZE:
        await message.reply_text(f"Just send me a file less than {MAX_UPLOAD_MB}MB 😎", quote=True)
        return
    
    uid = message.from_user.id
    today = datetime.date.today().isoformat()
    tracker = user_verification_tracker.setdefault(uid, {"date": today, "count": 0})
    
    if tracker["date"] != today:
        tracker.update({"date": today, "count": 0})
        
    if tracker["count"] < 1:
        tracker["count"] += 1
        ad_kb = InlineKeyboardMarkup([[InlineKeyboardButton("👉 Click Here and tap yes 👈", url="https://www.effectivegatecpm.com/c3576v9z?key=f971da0057995dacba3f0cd4266017e2")]])
        status_msg = await message.reply_text("⚠️ Please click the button below to continue! 👇", reply_markup=ad_kb, quote=True)
        await asyncio.sleep(10)
        await safe_execute(status_msg.edit_text("Downloading your file...", reply_markup=None))
    else:
        status_msg = await message.reply_text("Downloading your file...", quote=True)
    
    tmp_in = tempfile.NamedTemporaryFile(delete=False, dir=DOWNLOADS_DIR)
    tmp_in_path = tmp_in.name
    tmp_in.close()
    
    try:
        await client.download_media(message, file_name=tmp_in_path)
        await safe_execute(status_msg.edit_text("Processing..."))
        
        final_text = await transcribe_local_file_async(tmp_in_path, language=user_selected_lang.get(message.chat.id))
        if not final_text:
            raise ValueError()
            
        await safe_execute(status_msg.edit_text("Completed 😍"))
        await asyncio.sleep(1)
        await safe_execute(status_msg.delete())

        sent = await send_long_text(client, message.chat.id, final_text, message.id, uid)
        if sent:
            user_transcriptions.setdefault(message.chat.id, {})[sent.id] = {"text": final_text, "origin": message.id}
            if len(final_text) > 0:
                kb = build_action_keyboard(len(final_text))
                if kb:
                    await safe_execute(sent.edit_reply_markup(reply_markup=kb))
    except Exception:
        await show_error(client=client, chat_id=message.chat.id, reply_id=message.id)
    finally:
        if os.path.exists(tmp_in_path):
            await safe_execute(asyncio.to_thread(os.remove, tmp_in_path))

async def send_long_text(client, chat_id, text, reply_id, uid, action="Transcript"):
    if len(text) > MAX_MESSAGE_CHUNK:
        if get_user_mode(uid) == "Split messages":
            sent = None
            for i in range(0, len(text), MAX_MESSAGE_CHUNK):
                sent = await client.send_message(chat_id, text[i:i+MAX_MESSAGE_CHUNK], reply_to_message_id=reply_id)
            return sent
        else:
            fname = os.path.join(DOWNLOADS_DIR, f"{action}.txt")
            with open(fname, "w", encoding="utf-8") as f:
                f.write(text)
            sent = await client.send_document(chat_id, fname, caption="Open this file and copy the text inside 👍", reply_to_message_id=reply_id)
            os.remove(fname)
            return sent
    return await client.send_message(chat_id, text, reply_to_message_id=reply_id)

